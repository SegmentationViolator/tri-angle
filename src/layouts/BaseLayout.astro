---
import '../styles/global.scss';
import Navbar from '@components/layout/Navbar';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Tri-Angle — Independent Digital Studio',
  description = 'A cinematic freelancing studio crafting precise digital experiences.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#050505" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="preload"
      href="/fonts/Geist-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/GeistMono-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>{title}</title>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Navbar client:idle />
    <main id="main">
      <slot />
    </main>

    <script>
import '../scripts/lenis.client.ts';
import '../scripts/reveal.client.ts';
    </script>
  </body>
</html>
